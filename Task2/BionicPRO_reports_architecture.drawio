        <mxCell id="r1" value="Запрос отчёта" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="pilot" target="spa" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
