        <object placeholders="1" c4Name="Report Service (API)" c4Type="Container" c4Technology="FastAPI" c4Description="Эндпоинт /reports. Валидирует JWT в Keycloak, извлекает preferred_username, отдаёт только собственный отчёт пользователя из витрины (RBAC)." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="api">
