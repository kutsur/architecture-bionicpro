        <object placeholders="1" c4Name="OLAP БД (витрина)" c4Type="Container" c4Technology="ClickHouse" c4Description="Готовая витрина report_user_telemetry: аналитика телеметрии в разрезе пользователя. ORDER BY username даёт быстрый доступ по пользователю." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="olap">
