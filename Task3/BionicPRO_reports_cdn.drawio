            <mxGeometry x="1120" y="770" width="240" height="150" as="geometry" />
          </mxCell>
        </object>

        <mxCell id="c1" value="Запрос / скачивание" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="pilot" target="spa" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c2" value="GET /reports (Bearer)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="spa" target="api" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3" value="Валидация JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="api" target="kc" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c4" value="head/put reports/{username}.json" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="api" target="s3" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c5" value="SELECT только при промахе кеша" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="api" target="olap" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c6" value="Скачать отчёт по CDN-ссылке" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="spa" target="cdn" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c7" value="proxy + cache" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="cdn" target="s3" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c8" value="Построение витрины" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="etl" target="olap" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c9" value="Инвалидация кеша (удаление reports/)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="etl" target="s3" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
