          <mxCell style="shape=cylinder3;size=15;whiteSpace=wrap;html=1;boundedLbl=1;rounded=0;fillColor=#23A2D9;fontSize=12;fontColor=#ffffff;align=center;strokeColor=#0E7DAD;metaEdit=1;resizable=0;" parent="1" vertex="1">
            <mxGeometry x="1080" y="220" width="240" height="120" as="geometry" />
          </mxCell>
        </object>

        <!-- ================= AUTH КЛАСТЕР (новое) ================= -->
        <object placeholders="1" c4Name="reports-frontend" c4Type="Container" c4Technology="React, SPA" c4Description="Веб-приложение отчётов. Общается только с bionicpro-auth, токенов не хранит, использует session cookie." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="spa">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#23A2D9;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#0E7DAD;metaEdit=1;resizable=0;" parent="1" vertex="1">
            <mxGeometry x="420" y="440" width="240" height="120" as="geometry" />
          </mxCell>
        </object>
        <object placeholders="1" c4Name="bionicpro-auth" c4Type="Container" c4Technology="BFF / Auth Gateway" c4Description="Инициирует OAuth2 Authorization Code + PKCE. Хранит access/refresh токены на сервере, привязывает их к сессии. Фронтенду отдаёт только HttpOnly+Secure session cookie. Сам обновляет access_token через refresh_token. Токены IdP не покидают серверный контур." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="auth">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#1BA1E2;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#0E7DAD;metaEdit=1;resizable=0;" parent="1" vertex="1">
            <mxGeometry x="800" y="420" width="260" height="160" as="geometry" />
          </mxCell>
        </object>
        <object placeholders="1" c4Name="Keycloak" c4Type="Container" c4Technology="Authorization Server / Identity Broker" c4Description="Выпускает токены BionicPRO, требует PKCE (S256), брокерит внешние IdP разных стран (Identity Brokering), синхронизирует пользователей и роли из LDAP, MFA (OTP)." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="kc">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#1BA1E2;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#0E7DAD;metaEdit=1;resizable=0;" parent="1" vertex="1">
            <mxGeometry x="800" y="180" width="260" height="160" as="geometry" />
          </mxCell>
        </object>
        <object placeholders="1" c4Name="Session/Token Store" c4Type="Container" c4Technology="Redis" c4Description="Распределённый кеш. Хранит access/refresh токены в зашифрованном виде, привязанные к session id. Обеспечивает ротацию сессии." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#E6E6E6&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="redis">
          <mxCell style="shape=cylinder3;size=15;whiteSpace=wrap;html=1;boundedLbl=1;rounded=0;fillColor=#1BA1E2;fontSize=12;fontColor=#ffffff;align=center;strokeColor=#0E7DAD;metaEdit=1;resizable=0;" parent="1" vertex="1">
            <mxGeometry x="1200" y="440" width="240" height="140" as="geometry" />
          </mxCell>
        </object>

        <!-- ================= DEVICE / DATA ================= -->
        <object placeholders="1" c4Name="Программа в чипе протеза" c4Type="Software System" c4Description="Чтение данных с датчиков, распознавание движений и их воспроизводство, передача телеметрии." label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;font color=&quot;#cccccc&quot;&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="chip">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1061B0;fontColor=#ffffff;align=center;arcSize=10;strokeColor=#0D5091;metaEdit=1;resizable=0;" parent="1" vertex="1">
            <mxGeometry x="380" y="680" width="240" height="120" as="geometry" />
          </mxCell>
        </object>
        <object placeholders="1" c4Name="Приложение для донастройки протеза" c4Type="Container" c4Technology="iOS, Android" c4Description="" label="&lt;font style=&quot;font-size: 16px&quot;&gt;&lt;b&gt;%c4Name%&lt;/b&gt;&lt;/font&gt;&lt;div&gt;[%c4Type%: %c4Technology%]&lt;/div&gt;" id="mobile">
