        <!-- auth flow -->
        <mxCell id="e13" value="Скачивание отчёта о протезе (HTTPS)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="p_pilot" target="spa" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="Логин + запросы. Только session cookie (HttpOnly, Secure). Токены не передаются" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="spa" target="auth" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="OAuth2 Authorization Code + PKCE, обмен и refresh токенов [OIDC]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="auth" target="kc" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e16" value="Хранение access/refresh токенов, привязка к сессии (шифр.)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="auth" target="redis" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" value="Identity Brokering + LDAP federation. Данные учётных записей из страны представительства" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="kc" target="ext_idp" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
