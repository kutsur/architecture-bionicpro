        <mxCell id="e1" value="Выбор протеза, заказ, оплата" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="p_customer" target="shop" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
