        <mxCell id="e5" value="Предоставление миосигналов" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="p_pilot" target="chip" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="Управление протезом" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="mobile" target="chip" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="p_pilot" target="mobile" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="Отправка телеметрии" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" parent="1" source="chip" target="api" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
